# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
#
# Usage: these values are injected into BuildConfig via the
# gradle-dotenv-plugin (id 'co.uzzu.dotenv.gradle').
# Access them in code as: BuildConfig.TESTLAB_API_KEY

# TestLab credentials — get these from https://testlab.app/dashboard
TESTLAB_API_KEY=tl_live_xxxxxxxxxxxx
TESTLAB_APP_ID=app.testlab.example

# Set to true to enable SDK console logs during development
TESTLAB_DEBUG=true
