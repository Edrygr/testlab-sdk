# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
#
# Usage: install react-native-dotenv and add the babel plugin,
# then import directly: import { TESTLAB_API_KEY } from '@env'

# TestLab credentials — get these from https://testlab.app/dashboard
TESTLAB_API_KEY=tl_live_xxxxxxxxxxxx
TESTLAB_APP_ID=com.myapp

# Set to true to enable SDK console logs during development
TESTLAB_DEBUG=true
